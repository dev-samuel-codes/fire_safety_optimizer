{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "ViolationLabel",
  "type": "object",
  "required": [
    "rule_id",
    "status"
  ],
  "properties": {
    "rule_id": {
      "type": "string",
      "pattern": "^FV-(SPK|DET|EXT|HYD|EVA)-.+$"
    },
    "status": {
      "enum": [
        "violation",
        "compliant",
        "not_applicable",
        "needs_review"
      ]
    },
    "description": {
      "type": "string"
    },
    "evidence_geometry": {
      "type": "array"
    },
    "evidence_object_ids": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "measured_value": {},
    "required_value": {},
    "unit": {
      "type": "string"
    },
    "severity": {
      "enum": [
        "critical",
        "major",
        "minor",
        "info",
        ""
      ]
    },
    "source": {
      "enum": [
        "synthetic_gt",
        "model_pred",
        "expert",
        "rule_engine"
      ]
    }
  },
  "additionalProperties": false
}